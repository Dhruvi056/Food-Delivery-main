# MongoDB Connection String (Required)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/biteblitz?retryWrites=true&w=majority

# JWT Settings (Required)
JWT_SECRET=your_super_secret_jwt_key
JWT_REFRESH_SECRET=your_super_secret_refresh_key

# Stripe Payment Keys (Required for ordering)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# Redis Cache URL
REDIS_URL=redis://redis:6379

# SMTP Configuration (For 2FA / Order Emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password
SMTP_FROM=BiteBlitz <noreply@biteblitz.com>

# Twilio SMS Configuration (For Order SMS)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_number

# Hashing Algorithm iterations
SALT=10
PORT=4000
